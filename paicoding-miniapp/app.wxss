@import './styles/utils.wxss';

@font-face {
  font-family: 'DingTalk JinBuTi';
  src: url('https://cdn.paicoding.com/stutymore/pai-coding-DingTalk_JinBuTi.ttf') format('truetype');
}

.jinbuti {
  font-family: 'DingTalk JinBuTi';
}

@font-face {
  font-family: 'din bold';
  src: url('https://cdn.paicoding.com/stutymore/pai-coding-din-bold.ttf') format('truetype');
}

.din-bold {
  font-family: 'din bold';
}

page {
  min-height: 100%;
  background: #f6f7fb;
  color: #111827;
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", sans-serif;
  font-size: 28rpx;
  --td-input-prefix-icon-color: #c4c4c7;
  caret-color: #0BC196;
  --td-brand-color: #0BC196;
}

.shadow {
  box-shadow: 0px 9px 9px rgba(11, 193, 150, 0.1);
}


view,
text,
button,
input,
scroll-view {
  box-sizing: border-box;
}

button {
  padding: 0;
  border-radius: 0;
  background: transparent;
  line-height: inherit;
}

button::after {
  border: 0;
}

.page {
  min-height: 100vh;
  padding: 30rpx;
}

.panel {
  background: #ffffff;
  border: 1rpx solid #e5e7eb;
  border-radius: 8rpx;
}

.primary-button {
  height: 88rpx;
  border-radius: 100rpx;
  background: linear-gradient(to right, #0BC196, #1CE885);
  box-shadow: 0px 9px 9px rgba(11, 193, 150, 0.25);
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 600;
  line-height: 88rpx;
  text-align: center;
}

.muted {
  color: #64748b;
}

.state-card {
  padding: 64rpx 28rpx;
  text-align: center;
}

.state-title {
  color: #111827;
  font-size: 32rpx;
  font-weight: 700;
  line-height: 44rpx;
}

.state-desc {
  margin-top: 12rpx;
  font-size: 26rpx;
  line-height: 38rpx;
}

.retry-button {
  width: 220rpx;
  margin: 28rpx auto 0;
}

.flex-col-ic {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.gap-1 {
  gap: 4px;
}

.flex-ic {
  display: flex;
  align-items: center;
}