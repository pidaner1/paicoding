{
  "extends": "./tsconfig.shared.json",
  "compilerOptions": {
    "tsBuildInfoFile": "../node_modules/.tmp/tsconfig.node.tsbuildinfo",
    "target": "ES2023",
    "lib": [
      "ES2023"
    ],
    "types": [
      "node"
    ]
  },
  "include": [
    "../vite.config.ts",
    "../vite.config.*.ts",
    "../vite.config.mts",
    "../vite.config.*.mts",
    "../weapp-vite.config.ts",
    "../weapp-vite.config.*.ts",
    "../weapp-vite.config.mts",
    "../weapp-vite.config.*.mts",
    "../*.config.ts",
    "../*.config.mts",
    "../config/**/*.ts",
    "../config/**/*.mts",
    "../scripts/**/*.ts",
    "../scripts/**/*.mts"
  ]
}
