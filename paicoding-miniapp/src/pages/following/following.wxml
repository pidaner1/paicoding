<view class="following-page">
  <t-tabs value="{{activeTab}}" bind:change="switchTab" theme="line" space-evenly>
    <t-tab-panel value="follow" label="关注">
      <scroll-view class="user-scroll" scroll-y bindscrolltolower="loadMore" data-type="follow" refresher-enabled bindrefresherrefresh="refresh" refresher-triggered="{{follow.refreshing}}">
        <view class="list-content">
          <view wx:if="{{follow.error && follow.users.length === 0 && !follow.loading}}" class="state-card panel">
            <view class="state-title">加载失败</view>
            <view class="state-desc muted">{{follow.error}}</view>
            <button class="primary-button retry-button" data-type="follow" bindtap="retry">重试</button>
          </view>
          <view wx:elif="{{follow.users.length === 0 && !follow.loading}}" class="empty panel">暂未关注任何人</view>
          <view wx:for="{{follow.users}}" wx:key="userId" class="user-row panel">
            <image wx:if="{{item.avatar}}" class="avatar" src="{{item.avatar}}" mode="aspectFill" />
            <view wx:else class="avatar avatar-placeholder">{{item.userInitial}}</view>
            <text class="user-name">{{item.userName}}</text>
            <button class="relationship-button relationship-button--followed" data-type="follow" data-id="{{item.userId}}" loading="{{item.submitting}}" disabled="{{item.submitting}}" bindtap="toggleRelationship">已关注</button>
          </view>
          <view wx:if="{{follow.users.length > 0}}" class="load-state muted">{{follow.loading ? '加载中' : (follow.hasMore ? '上拉加载更多' : '没有更多了')}}</view>
        </view>
      </scroll-view>
    </t-tab-panel>

    <t-tab-panel value="fans" label="粉丝">
      <scroll-view class="user-scroll" scroll-y bindscrolltolower="loadMore" data-type="fans" refresher-enabled bindrefresherrefresh="refresh" refresher-triggered="{{fans.refreshing}}">
        <view class="list-content">
          <view wx:if="{{fans.error && fans.users.length === 0 && !fans.loading}}" class="state-card panel">
            <view class="state-title">加载失败</view>
            <view class="state-desc muted">{{fans.error}}</view>
            <button class="primary-button retry-button" data-type="fans" bindtap="retry">重试</button>
          </view>
          <view wx:elif="{{fans.users.length === 0 && !fans.loading}}" class="empty panel">暂无粉丝</view>
          <view wx:for="{{fans.users}}" wx:key="userId" class="user-row panel">
            <image wx:if="{{item.avatar}}" class="avatar" src="{{item.avatar}}" mode="aspectFill" />
            <view wx:else class="avatar avatar-placeholder">{{item.userInitial}}</view>
            <text class="user-name">{{item.userName}}</text>
            <button class="relationship-button {{item.followed ? 'relationship-button--followed' : ''}}" data-type="fans" data-id="{{item.userId}}" loading="{{item.submitting}}" disabled="{{item.submitting}}" bindtap="toggleRelationship">{{item.followed ? '已互关' : '回关'}}</button>
          </view>
          <view wx:if="{{fans.users.length > 0}}" class="load-state muted">{{fans.loading ? '加载中' : (fans.hasMore ? '上拉加载更多' : '没有更多了')}}</view>
        </view>
      </scroll-view>
    </t-tab-panel>
  </t-tabs>
</view>
