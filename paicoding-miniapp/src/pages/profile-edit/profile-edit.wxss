.profile-edit-page {
  min-height: 100vh;
  padding: 48rpx 30rpx;
  box-sizing: border-box;
  background: #f6f7fb;
}

.avatar-section {
  display: flex;
  justify-content: center;
  margin: 16rpx 0 48rpx;
}

.avatar-button {
  position: relative;
  width: 168rpx;
  height: 168rpx;
  padding: 0;
  border-radius: 50%;
  overflow: hidden;
  background: transparent;
}

.avatar-button::after {
  border: 0;
}

.avatar-preview {
  width: 168rpx;
  height: 168rpx;
  border-radius: 50%;
  background: #eef2f7;
}

.avatar-mask {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 48rpx;
  line-height: 48rpx;
  color: #fff;
  font-size: 22rpx;
  text-align: center;
  background: rgba(0, 0, 0, 0.42);
}

.form-card {
  padding: 0 30rpx;
  border-radius: 20rpx;
  background: #fff;
}

.form-item {
  min-height: 112rpx;
  display: flex;
  align-items: center;
  border-bottom: 1rpx solid #edf1f5;
}

.form-item:last-child {
  border-bottom: 0;
}

.form-item-column {
  display: block;
  padding: 32rpx 0;
}

.form-row {
  display: flex;
  align-items: center;
}

.form-label {
  width: 112rpx;
  color: #333;
  font-size: 30rpx;
  font-weight: 600;
}

.form-input {
  flex: 1;
  height: 80rpx;
  color: #333;
  font-size: 30rpx;
}

.form-count {
  flex: 1;
  color: #9aa4b2;
  font-size: 24rpx;
  text-align: right;
}

.form-textarea {
  width: 100%;
  height: 220rpx;
  margin-top: 24rpx;
  color: #333;
  font-size: 30rpx;
  line-height: 1.6;
}

.save-button {
  height: 92rpx;
  line-height: 92rpx;
  margin-top: 44rpx;
  border-radius: 46rpx;
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  background: linear-gradient(135deg, #43CF7C, #51C496);
  box-shadow: 0 4px 10px 4px #43CF7C50;
}

.save-button::after {
  border: 0;
}

.save-button[disabled] {
  color: rgba(255, 255, 255, 0.8);
  background: #a7e8cb;
}
